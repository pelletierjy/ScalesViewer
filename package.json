{
  "name": "gscale",
  "version": "0.1.0",
  "private": true,
  "description": "A musical scale visualization tool",
  "author": {
    "name": "Jean-Yves",
    "email": "your.email@example.com"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:piano": "playwright test e2e/piano",
    "test:e2e:report": "playwright show-report",
    "test:cucumber": "cucumber-js",
    "test:cucumber:piano": "cucumber-js --tags @piano",
    "test:cucumber:report": "cucumber-js --format html:reports/cucumber-report.html",
    "test:cucumber:smoke": "cucumber-js --tags @smoke",
    "playwright:install": "playwright install",
    "playwright:install-deps": "playwright install-deps",
    "build-mobile": "next build",
    "cap-init": "cap init",
    "cap-add-android": "cap add android",
    "cap-sync": "cap sync",
    "android": "cap open android",
    "android-build": "npm run build-mobile && cap sync && cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@vercel/analytics": "^2.0.1",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-redux": "^9.3.0",
    "tsconfig-paths": "^4.2.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.4",
